{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/today",
      "destination": "/today.html"
    },
    {
      "source": "/library",
      "destination": "/library.html"
    },
    {
      "source": "/progress",
      "destination": "/progress.html"
    },
    {
      "source": "/settings",
      "destination": "/settings.html"
    },
    {
      "source": "/exercise/:exerciseId",
      "destination": "/exercise/:exerciseId.html"
    }
  ]
}
